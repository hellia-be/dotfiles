Xft.dpi: 96
Xft.antialias: true
Xft.hinting: true
Xft.rgba: rgb
Xft.autohint: false
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault

*background: #0c0c0c
*foreground: #ebebeb
*fading: 8
*fadeColor: black
*cursorColor: #ebebeb
*pointerColorBackground: #0c0c0c
*pointerColorForeground: #ebebeb

Xcursor.theme: xcursor-breeze
Xcursor.size: 0
